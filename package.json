{
  "name": "@andreasphil/design-system",
  "version": "0.57.0",
  "description": "Small, opinionated CSS framework to make sites look good with minimal effort",
  "license": "MIT",
  "author": "Andreas Philippi",
  "repository": "https://github.com/andreasphil/design-system",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./style.css": {
      "import": "./dist/design-system.css",
      "default": "./dist/design-system.css"
    },
    "./utils.css": {
      "import": "./dist/design-system-utils.css",
      "default": "./dist/design-system-utils.css"
    }
  },
  "scripts": {
    "dev": "node ./build --watch",
    "build": "node ./build",
    "bump-version": "node --run build && git add ./dist && pnpm version minor --no-git-checks"
  },
  "devDependencies": {
    "lightningcss": "^1.32.0"
  }
}
